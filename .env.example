# FordLogger environment variables
# Copy to .env and adjust as needed

# Store raw API JSON responses in the database (default: true)
# Useful for debugging and verifying parser correctness
# Set to false to save disk space once parsing is stable
FORDLOGGER_STORE_RAW_JSON=true

# Reverse geocode trip start/end and charge locations to addresses (default: true)
# Uses OpenStreetMap Nominatim (free, no API key needed)
FORDLOGGER_GEOCODING=true
