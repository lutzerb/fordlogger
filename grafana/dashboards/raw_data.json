          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "rawSql": "SELECT start_ts AS \"start\", end_ts AS \"end\", duration_s AS \"duration\", start_soc_pct AS \"start_soc\", end_soc_pct AS \"end_soc\", soc_added_pct AS \"soc_added\", energy_added_kwh, max_power_kw, avg_power_kw, charge_type, outside_temp_c AS \"temp\", address, lat, lon FROM charge_sessions WHERE vin = '$vin' AND  $__timeFilter(start_ts) ORDER BY start_ts DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "State Transitions",
      "type": "table",
      "gridPos": {
