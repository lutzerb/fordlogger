{
  "uid": "fordlogger-raw-data",
  "title": "Raw Data Explorer",
  "description": "Browse raw telemetry, trips, charge sessions, and state transitions",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": [
    "fordlogger"
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "",
  "panels": [
    {
      "id": 1,
      "title": "Positions (Telemetry Snapshots)",
      "type": "table",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "FordLogger"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "lat"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 6
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "lon"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 6
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "soc_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "range_km"
            },
            "properties": [
              {
                "id": "unit",
                "value": "km"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "speed_kmh"
            },
            "properties": [
              {
                "id": "unit",
                "value": "km/h"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "bat_temp_c"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "outside_temp_c"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "charge_power_kw"
            },
            "properties": [
              {
                "id": "unit",
                "value": "kwatt"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "ts",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "rawSql": "SELECT ts, soc_pct, range_km, odometer_km, speed_kmh, lat, lon, heading, bat_temp_c, outside_temp_c, bat_voltage, bat_current_a, energy_remaining_kwh, bat_capacity_kwh, plug_status, charge_status, charge_power_kw, charger_voltage, charger_current_a, tire_pressure_fl, tire_pressure_fr, tire_pressure_rl, tire_pressure_rr, door_lock_status, ignition_status, state, raw_json::text as raw_api_response FROM positions WHERE vin = '$vin' AND  $__timeFilter(ts) ORDER BY ts DESC LIMIT 500",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Trips",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "FordLogger"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "distance_km"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "unit",
                "value": "km"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "consumption"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "unit",
                "value": "kWh/100km"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "duration"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "avg_speed_kmh"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "unit",
                "value": "km/h"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "max_speed_kmh"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "unit",
                "value": "km/h"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "start_soc"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "end_soc"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "energy_used_kwh"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "unit",
                "value": "kwatth"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "temp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "sortBy": [
          {
            "displayName": "start",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "rawSql": "SELECT start_ts AS \"start\", end_ts AS \"end\", duration_s AS \"duration\", distance_km, start_soc_pct AS \"start_soc\", end_soc_pct AS \"end_soc\", soc_used_pct AS \"soc_used\", energy_used_kwh, consumption_kwh_per_100km AS \"consumption\", avg_speed_kmh, max_speed_kmh, outside_temp_c AS \"temp\", start_address, end_address, start_lat, start_lon, end_lat, end_lon FROM trips WHERE vin = '$vin' AND  $__timeFilter(start_ts) ORDER BY start_ts DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ]
    },
