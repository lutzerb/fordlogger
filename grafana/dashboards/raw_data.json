  "templating": {
    "list": [
      {
        "name": "vin",
        "label": "Vehicle",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "FordLogger"
        },
        "query": "SELECT vin FROM vehicles ORDER BY vin",
        "refresh": 2,
        "sort": 0,
        "includeAll": false,
        "current": {}
      }
    ]
  }
