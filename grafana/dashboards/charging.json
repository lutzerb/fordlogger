          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  ts AS \"time\",\n  charge_power_kw AS \"Charge Power\"\nFROM positions\nWHERE $__timeFilter(ts)\n  AND charge_power_kw > 0\nORDER BY ts;",
          "refId": "A"
        }
      ]
