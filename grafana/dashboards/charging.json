          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(energy_added_kwh), 0) AS \"Total Energy (kWh)\" FROM charge_sessions WHERE start_ts >= $__timeFrom() AND start_ts <= $__timeTo();",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Average Session Duration",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": {
        "type": "postgres",
        "uid": "FordLogger"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "m",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
