      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        },
        "sortBy": [
          {
            "displayName": "Start",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  start_ts,\n  COALESCE(address, '') AS location,\n  charge_type,\n  start_soc_pct,\n  end_soc_pct,\n  soc_added_pct,\n  energy_added_kwh,\n  max_power_kw,\n  ROUND(duration_s / 60.0, 0) AS duration_min,\n  outside_temp_c\nFROM charge_sessions\nWHERE start_ts >= $__timeFrom()\n  AND start_ts <= $__timeTo()\nORDER BY start_ts DESC;",
          "refId": "A"
        }
      ]
    },
