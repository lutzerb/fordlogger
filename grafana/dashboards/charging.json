{
  "uid": "fordlogger-charging",
  "title": "Charging",
  "description": "FordLogger charging sessions and charge curves",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "",
  "tags": ["fordlogger", "charging"],
  "time": {
    "from": "now-30d",
    "to": "now"
