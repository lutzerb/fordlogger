          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(MAX(max_power_kw), 0) AS \"Max Power (kW)\" FROM charge_sessions WHERE start_ts >= $__timeFrom() AND start_ts <= $__timeTo();",
          "refId": "A"
        }
      ]
    },
    {
