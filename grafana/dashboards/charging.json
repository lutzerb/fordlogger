        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(AVG(duration_s) / 60.0, 0), 0) AS \"Avg Duration (min)\" FROM charge_sessions WHERE start_ts >= $__timeFrom() AND start_ts <= $__timeTo();",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Max Power Seen",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
