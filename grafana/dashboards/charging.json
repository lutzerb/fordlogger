      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  ts AS \"time\",\n  soc_pct AS \"SoC\"\nFROM positions\nWHERE $__timeFilter(ts)\n  AND state = 'charging'\nORDER BY ts;",
