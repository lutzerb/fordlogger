      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "FordLogger"
          },
          "rawSql": "SELECT\n  start_ts AS \"Start\",\n  COALESCE(start_address, '') AS \"From\",\n  COALESCE(end_address, '') AS \"To\",\n  distance_km AS \"Distance km\",\n  CASE\n    WHEN duration_s >= 3600 THEN\n      CONCAT(FLOOR(duration_s / 3600)::TEXT, 'h ', LPAD((FLOOR(duration_s % 3600 / 60))::TEXT, 2, '0'), 'm')\n    ELSE\n      CONCAT(FLOOR(duration_s / 60)::TEXT, 'm ', LPAD((duration_s % 60)::TEXT, 2, '0'), 's')\n  END AS \"Duration\",\n  start_soc_pct AS \"Start SoC %\",\n  end_soc_pct AS \"End SoC %\",\n  soc_used_pct AS \"SoC Used %\",\n  consumption_kwh_per_100km AS \"Consumption\",\n  avg_speed_kmh AS \"Avg Speed\",\n  max_speed_kmh AS \"Max Speed\",\n  outside_temp_c AS \"Outside Temp\"\nFROM trips\nWHERE vin = '$vin' AND  start_ts >= $__timeFrom() AND start_ts <= $__timeTo()\nORDER BY start_ts DESC;",
          "format": "table",
          "editorMode": "code"
        }
      ]
